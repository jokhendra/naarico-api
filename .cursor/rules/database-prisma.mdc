### Query Optimization
```typescript
// Use select to limit fields
async findProductTitles(): Promise<{ id: string; title: string }[]> {
  return this.prismaService.product.findMany({
    select: {
      id: true,
      title: true,
    },
    where: { isActive: true },
  });
}

// Use distinct for unique values
async findUniqueBrands(): Promise<string[]> {
  const brands = await this.prismaService.product.findMany({
    select: { brand: { select: { name: true } } },
    where: { isActive: true },
    distinct: ['brandId'],
  });
  
  return brands.map(b => b.brand?.name).filter(Boolean);
}

// Use raw queries for complex operations
async getProductSalesReport(startDate: Date, endDate: Date): Promise<SalesReport[]> {
  return this.prismaService.$queryRaw`
    SELECT 
      p.id,
      p.title,
      COUNT(oi.id) as total_orders,
      SUM(oi.quantity) as total_quantity,
      SUM(oi.price * oi.quantity) as total_revenue
    FROM products p
    LEFT JOIN order_items oi ON p.id = oi.product_id
    LEFT JOIN orders o ON oi.order_id = o.id
    WHERE o.created_at BETWEEN ${startDate} AND ${endDate}
    GROUP BY p.id, p.title
    ORDER BY total_revenue DESC
  `;
}
```

This ensures efficient, scalable database operations with proper transaction handling, query optimization, and data transformation patterns.