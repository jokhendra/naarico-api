## 🔍 Advanced Query Patterns

### Complex Filtering with Relations
```typescript
async findProductsWithAdvancedFilters(filters: AdvancedProductFilters): Promise<Product[]> {
  const where: Prisma.ProductWhereInput = {
    isActive: true,
  };

  // Category hierarchy filtering
  if (filters.categoryId) {
    const categoryIds = await this.getCategoryAndDescendantsIds(filters.categoryId);
    where.OR = [
      { categoryId: { in: categoryIds } },
      { subCategoryId: { in: categoryIds } },
    ];
  }

  // Brand filtering
  if (filters.brandIds && filters.brandIds.length > 0) {
    where.brandId = { in: filters.brandIds };
  }

  // Tag filtering
  if (filters.tagIds && filters.tagIds.length > 0) {
    where.tags = {
      some: {
        tagId: { in: filters.tagIds },
      },
    };
  }

  // Price range filtering
  if (filters.priceRange) {
    where.price = {
      gte: filters.priceRange.min,
      lte: filters.priceRange.max,
    };
  }

  // Stock filtering
  if (filters.inStock !== undefined) {
    where.stockQuantity = filters.inStock ? { gt: 0 } : { equals: 0 };
  }

  // Rating filtering
  if (filters.minRating) {
    where.averageRating = { gte: filters.minRating };
  }

  return this.prismaService.product.findMany({
    where,
    include: {
      brand: true,
      category: true,
      images: { orderBy: { position: 'asc' } },
      variants: true,
      tags: { include: { tag: true } },
    },
    orderBy: this.buildOrderBy(filters.sortBy, filters.sortOrder),
  });
}
```

### Aggregation Queries
```typescript
async getProductAnalytics(sellerId?: string): Promise<ProductAnalytics> {
  const where: Prisma.ProductWhereInput = {};
  
  if (sellerId) {
    where.sellerId = sellerId;
  }

  const [
    totalProducts,
    activeProducts,
    lowStockProducts,
    averagePrice,
    priceRange,
  ] = await Promise.all([
    this.prismaService.product.count({ where }),
    this.prismaService.product.count({ where: { ...where, isActive: true } }),
    this.prismaService.product.count({
      where: { ...where, stockQuantity: { lte: 5 } },
    }),
    this.prismaService.product.aggregate({
      where,
      _avg: { price: true },
    }),
    this.prismaService.product.aggregate({
      where,
      _min: { price: true },
      _max: { price: true },
    }),
  ]);

  return {
    totalProducts,
    activeProducts,
    lowStockProducts,
    averagePrice: averagePrice._avg.price || 0,
    minPrice: priceRange._min.price || 0,
    maxPrice: priceRange._max.price || 0,
  };
}
```

## 🔄 Data Transformation Patterns

### Entity to DTO Transformation
```typescript
private transformProductToDto(product: any): ProductResponseDto {
  return {
    id: product.id,
    title: product.title,
    slug: product.slug,
    description: product.description,
    price: product.price,
    discountPrice: product.discountPrice,
    stockQuantity: product.stockQuantity,
    isActive: product.isActive,
    isFeatured: product.isFeatured,
    createdAt: product.createdAt,
    updatedAt: product.updatedAt,
    
    // Transform nested objects
    brand: product.brand ? {
      id: product.brand.id,
      name: product.brand.name,
      logo: product.brand.logo,
    } : null,
    
    category: product.category ? {
      id: product.category.id,
      name: product.category.name,
      slug: product.category.slug,
    } : null,
    
    images: product.images?.map((image: any) => ({
      id: image.id,
      imageUrl: image.imageUrl,
      altText: image.altText,
      position: image.position,
    })) || [],
    
    variants: product.variants?.map((variant: any) => ({
      id: variant.id,
      variantName: variant.variantName,
      price: variant.price,
      stockQuantity: variant.stockQuantity,
    })) || [],
    
    tags: product.tags?.map((productTag: any) => ({
      id: productTag.tag.id,
      name: productTag.tag.name,
    })) || [],
  };
}
```

